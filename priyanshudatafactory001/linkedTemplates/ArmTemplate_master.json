{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "priyanshudatafactory001"
		},
		"LS_SQL server_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQL server'"
		},
		"ls_ADLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_ADLS'"
		},
		"LS_SQL server_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "priyanshudfpro.database.windows.net"
		},
		"LS_SQL server_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "Priyanshu_DB"
		},
		"LS_SQL server_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "priyanshu"
		},
		"ls_ADLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://priyanshustorageaccount.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "priyanshudatafactory001_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_SQL server_password": {
						"value": "[parameters('LS_SQL server_password')]"
					},
					"ls_ADLS_accountKey": {
						"value": "[parameters('ls_ADLS_accountKey')]"
					},
					"LS_SQL server_properties_typeProperties_server": {
						"value": "[parameters('LS_SQL server_properties_typeProperties_server')]"
					},
					"LS_SQL server_properties_typeProperties_database": {
						"value": "[parameters('LS_SQL server_properties_typeProperties_database')]"
					},
					"LS_SQL server_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQL server_properties_typeProperties_userName')]"
					},
					"ls_ADLS_properties_typeProperties_url": {
						"value": "[parameters('ls_ADLS_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}